# ─────────────────────────────────────────────────────────────────────────────
# Charlie — Cognitive Operating System
# Environment configuration — place this file at the ROOT of the project
#
# Copy this file to .env at the project root:
#   cp .env.example .env
#
# The .env file is listed in .gitignore and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (SQLite — no server required) ───────────────────────────────────
# Default: auto-resolved relative to the backend/ directory.
# Override only if you want a custom path.
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/Brain/backend/charlie.db
# DATABASE_URL_SYNC=sqlite:////absolute/path/to/Brain/backend/charlie.db

# ── Knowledge base ───────────────────────────────────────────────────────────
# Default: auto-resolved to knowledge/ inside the project root.
# Override only if you want a custom path.
# KNOWLEDGE_BASE_PATH=/absolute/path/to/Brain/knowledge

# ── Debug mode ───────────────────────────────────────────────────────────────
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider — choose ONE of the two options below
# ─────────────────────────────────────────────────────────────────────────────

# ── OPTION A: Ollama (default — local, free, no API key required) ─────────────
# Install Ollama: https://ollama.com
# Pull the model: ollama pull gemma3:270m
# Then start Charlie normally — it will connect automatically.
#
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:270m

# Per-level model overrides (optional — falls back to OLLAMA_MODEL if empty)
# Use a smaller/faster model for L1 classification to reduce latency:
# OLLAMA_MODEL_L1=gemma3:4b
# OLLAMA_MODEL_L2=gemma3:270m
# OLLAMA_MODEL_L3=gemma3:270m

# ── OPTION B: OpenAI API (cloud, requires API key) ────────────────────────────
# Uncomment and fill in to switch to OpenAI.
# Also change AI_PROVIDER=openai above.
#
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=   # leave empty for default api.openai.com

# Per-level OpenAI model overrides (optional — defaults shown)
# AI_MODEL_L1=gpt-4o-mini
# AI_MODEL_L2=gpt-4o-mini
# AI_MODEL_L3=gpt-4o

# ── AI Parameters (optional — defaults shown) ────────────────────────────────
# AI_MAX_TOKENS_L1=512
# AI_MAX_TOKENS_L2=2048
# AI_MAX_TOKENS_L3=4096

# AI_TEMPERATURE_L1=0.1
# AI_TEMPERATURE_L2=0.4
# AI_TEMPERATURE_L3=0.7
